    {
      "id": "a1b2c3d4-1111-4000-a000-000000000001",
      "name": "Horizon Morning Brief",
      "enabled": true,
      "createdAtMs": 1776900000000,
      "updatedAtMs": 1776905980529,
      "schedule": {
        "kind": "cron",
        "expr": "50 6 * * *",
        "tz": "Asia/Ho_Chi_Minh"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "Run News Digest Agent for batch: morning\n\n1. Determine today's date in YYYY-MM-DD format.\n2. Use web fetch to retrieve the Markdown file from: https://juliuss1907.github.io/Horizon/horizon-{today}-morning-vi.md\n   - If the Vietnamese version returns 404, try: https://juliuss1907.github.io/Horizon/horizon-{today}-morning-en.md\n   - If both return 404, report: '❌ Horizon morning report not available yet. GitHub Actions may still be running.'\n3. If the fetch succeeds, format the content as follows:\n   - Start with: 🌅 MORNING BRIEF — Thế Giới & AI\n   - Add: 📅 {today's date}\n   - Add a separator line: ──────────────────────────────\n   - Include the full fetched Markdown content (clean up excessive blank lines)\n   - End with separator and: Reply \"lưu [số]\" để ingest | \"lưu all\" | \"skip\"\n4. Send the formatted message as your response.",
        "model": "minimax/MiniMax-M2.7"
      },
      "delivery": {
        "mode": "announce",
        "channel": "telegram",
        "to": "1370258715"
      },
      "state": {
        "nextRunAtMs": 1776988200000,
        "lastRunAtMs": 1776905860179,
        "lastRunStatus": "ok",
        "lastStatus": "ok",
        "lastDurationMs": 120350,
        "lastDelivered": true,
