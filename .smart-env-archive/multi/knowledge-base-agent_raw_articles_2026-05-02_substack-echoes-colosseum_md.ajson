như quy trình#{2}":[49,49],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Cái chết được quản lý như quy trình#{3}":[50,50],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Cái chết được quản lý như quy trình#{4}":[51,52],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Cái chết được quản lý như quy trình#{5}":[53,56],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Xử lý thi thể — từ ngôi sao thành phế thảI":[57,70],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Xử lý thi thể — từ ngôi sao thành phế thảI#{1}":[59,61],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Xử lý thi thể — từ ngôi sao thành phế thảI#{2}":[62,62],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Xử lý thi thể — từ ngôi sao thành phế thảI#{3}":[63,64],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Xử lý thi thể — từ ngôi sao thành phế thảI#{4}":[65,65],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Xử lý thi thể — từ ngôi sao thành phế thảI#{5}":[66,66],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Xử lý thi thể — từ ngôi sao thành phế thảI#{6}":[67,68],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Xử lý thi thể — từ ngôi sao thành phế thảI#{7}":[69,70],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Nghĩa trang tập thể (_puticuli_)":[71,78],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Nghĩa trang tập thể (_puticuli_)#{1}":[73,78],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#NgoạI lệ hiếm hoi — _collegia_":[79,86],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#NgoạI lệ hiếm hoi — _collegia_#{1}":[81,86],"#Tiếng vọng từ Đấu trường La Mã — Sự thật đen tối đằng sau trò giải trí#Ý nghĩa":[87,92],"#Tiếng vọng từ Đấu trườn